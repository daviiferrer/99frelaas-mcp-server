{
  "name": "99freelas-mcp-server",
  "version": "0.2.0",
  "private": true,
  "description": "Private/local MCP adapter for 99Freelas using stdio transport.",
  "license": "MIT",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "npm run build && node dist/index.js",
    "dev:http": "npm run build && node dist/http.js",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "web:build": "esbuild web/src/main.tsx --bundle --format=esm --target=es2022 --loader:.png=dataurl --outdir=web/dist --entry-names=dashboard",
    "docker:build": "docker compose build 99freelas-mcp-server",
    "docker:rebuild": "docker compose build --no-cache 99freelas-mcp-server",
    "docker:up": "docker compose up -d --build --force-recreate --remove-orphans",
    "docker:run": "npm run docker:up",
    "docker:down": "docker compose down --remove-orphans",
    "test": "npm run build && node --test tests/**/*.test.cjs",
    "coverage": "npm run build && c8 --all --include=dist/**/*.js --exclude=dist/**/*.d.ts --exclude=dist/index.js --exclude=dist/storage/stateDatabase.js --check-coverage --lines 100 --functions 100 --statements 100 node --test tests/**/*.test.cjs"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.5",
    "playwright": "^1.53.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "c8": "^10.1.3",
    "esbuild": "^0.25.9",
    "typescript": "^5.7.2"
  }
}
